{
  "name": "lmfaole",
  "version": "1.0.0",
  "private": true,
  "description": "Overview of design systems, their contents, and shared UI patterns.",
  "scripts": {
    "typecheck": "astro check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "dev": "astro dev",
    "build": "astro build",
    "start": "astro preview",
    "test": "pnpm run test:contract",
    "test:contract": "node --import tsx --test tests/**/*.test.ts",
    "lint": "pnpm run typecheck && pnpm run lint:styles && pnpm run lint:commit && pnpm run lint:repo",
    "lint:commit": "node scripts/lint-commit-message.mjs",
    "lint:repo": "node scripts/lint-repo-rules.mjs",
    "lint:styles": "stylelint --allow-empty-input \"src/**/*.{css,scss}\"",
    "lint:styles:fix": "stylelint --allow-empty-input \"src/**/*.{css,scss}\" --fix",
    "pages:dev": "pnpm run build && npx wrangler pages dev dist",
    "pages:build": "pnpm run build",
    "pages:deploy": "pnpm run build && npx wrangler pages deploy dist --project-name=lmfaole"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lmfaole/design-systems-overview.git"
  },
  "keywords": [
    "astro",
    "cloudflare-pages",
    "design-system",
    "documentation"
  ],
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/lmfaole/design-systems-overview/issues"
  },
  "homepage": "https://lmfaole.party",
  "dependencies": {
    "@fremtind/jokul": "^4.3.0",
    "@lmfaole/basics": "github:lmfaole/basics#e1ea0934ebb984f2705c0a7873171f262d6042c2",
    "astro": "^6.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "postcss-scss": "^4.0.9",
    "sass": "^1.98.0",
    "stylelint": "^17.5.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.3"
}
