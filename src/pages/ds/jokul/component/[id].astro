---
import JokulLayout from "@/layouts/JokulLayout.astro";
import { componentDocs, getComponentDoc } from "@/data/jokul/component-docs";
import { getPatternBacklinksForComponentHref } from "@/data/monster/patterns";
import ComponentDetailPage from "@/features/ds/jokul/components/ComponentDetailPage/Page.astro";

export function getStaticPaths() {
    return componentDocs.map((doc) => ({
        params: { id: doc.id },
    }));
}

const { id } = Astro.params;
const doc = getComponentDoc(id ?? "");

if (!doc) {
    throw new Error(`Missing component for id "${id}"`);
}

const relatedPatterns = getPatternBacklinksForComponentHref(`/ds/jokul/component/${doc.id}`);
---

<JokulLayout
    title={`${doc.name} i Jøkul`}
    description={doc.description.long}
    path={`/ds/jokul/component/${doc.id}`}
>
    <ComponentDetailPage doc={doc} relatedPatterns={relatedPatterns} />
</JokulLayout>
