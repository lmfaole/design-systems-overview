---
import JokulLayout from "@/layouts/JokulLayout.astro";
import { getTokenPost, getTokenSlug, tokenPosts } from "@/data/jokul/tokens";
import TokenPostPage from "@/features/ds/jokul/tokens/TokenPostPage.astro";

export function getStaticPaths() {
    return tokenPosts.map((post) => ({
        params: { slug: getTokenSlug(post) },
    }));
}

const { slug } = Astro.params;
const post = getTokenPost(slug ?? "");

if (!post) {
    throw new Error(`Missing token for slug "${slug}"`);
}
---

<JokulLayout
    title={`${post.title} i Jøkul`}
    description={post.excerpt}
    path={`/ds/jokul/token/${slug}`}
    type="article"
>
    <TokenPostPage post={post} />
</JokulLayout>
