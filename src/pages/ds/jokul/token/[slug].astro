---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Flex } from "@fremtind/jokul/flex";
import { getTokenPost, getTokenSlug, tokenPosts } from "@/app/ds/_data/jokul-tokens";
import { TokenPostPageClient } from "@/app/(ds)/ds/jokul/token/[slug]/TokenPostPageClient";
import { ResourceSection } from "@/app/ds/jokul/_shared/components/ResourceList/ResourceSection";

export function getStaticPaths() {
    return tokenPosts.map((post) => ({
        params: { slug: getTokenSlug(post) },
    }));
}

const { slug } = Astro.params;
const post = getTokenPost(slug ?? "");

if (!post) {
    throw new Error(`Missing token for slug "${slug}"`);
}
---

<BaseLayout
    title={`${post.title} i Jøkul`}
    description={post.excerpt}
    path={`/ds/jokul/token/${slug}`}
    type="article"
    jokulTheme={true}
>
    <Flex className="page" direction="column" gap="xl">
        <TokenPostPageClient slug={slug!} />
        {post.resources && post.resources.length > 0 && (
            <div className="post-prose" data-kind="pattern">
                <ResourceSection
                    items={post.resources.map((resource) => ({
                        title: resource.title,
                        href: resource.url,
                        publisher: resource.publisher,
                        relevance: resource.relevance,
                        description: resource.description,
                    }))}
                />
            </div>
        )}
    </Flex>
</BaseLayout>
