---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPatternPost, patternPosts } from "@/data/monster/patterns";
import { PageHeader } from "@/components/ds/PageHeader";
import { PatternTableOfContents } from "@/features/ds/monster/detail/components";
import { DoAndDontsSection } from "@/features/ds/monster/detail/DoAndDontsSection";
import { AccessibilitySection } from "@/features/ds/monster/detail/AccessibilitySection";
import { ImplementationSection } from "@/features/ds/monster/detail/ImplementationSection";
import { ResourceSection } from "@/features/ds/monster/detail/ResourceSection";
import { MONSTER_PATTERN_SECTIONS } from "@/features/ds/monster/detail/sections";
import PatternPostEnhancements from "@/features/ds/monster/posts/components/PatternPostEnhancements.astro";
import "@/features/ds/monster/detail/monster-detail.scss";

export function getStaticPaths() {
    return patternPosts.map((post) => ({
        params: { id: String(post.id) },
    }));
}

const { id } = Astro.params;
const post = getPatternPost(id ?? "");

if (!post) {
    throw new Error(`Missing pattern for id "${id}"`);
}

const Illustration = post.illustration.component;
const tableOfContentsItems = [
    MONSTER_PATTERN_SECTIONS.doAndDonts,
    ...(post.accessibilityConcerns.length > 0
        ? [MONSTER_PATTERN_SECTIONS.accessibility]
        : []),
    ...(post.implementation.length > 0
        ? [MONSTER_PATTERN_SECTIONS.implementation]
        : []),
    ...(post.furtherReading.length > 0
        ? [MONSTER_PATTERN_SECTIONS.furtherReading]
        : []),
];
---

<BaseLayout
    title={post.title}
    description={post.description}
    path={`/ds/monster/${post.id}`}
    type="article"
>
    <main class="page">
        <PageHeader title={post.title} description={post.description} background={Illustration} />
        <PatternTableOfContents items={tableOfContentsItems} />

        <DoAndDontsSection doAndDonts={post.doAndDonts} />
        <AccessibilitySection concerns={post.accessibilityConcerns} />
        <ImplementationSection implementations={post.implementation} />
        <ResourceSection items={post.furtherReading} />
    </main>
    <PatternPostEnhancements />
</BaseLayout>
