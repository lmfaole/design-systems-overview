---
import type { OverviewSummaryStat } from "@/data/overview";

interface Props {
    items: OverviewSummaryStat[];
}

const { items } = Astro.props;
---

<ul>
    {items.map((item) => (
        <li>
            <article>
                <p>
                    <strong>{item.value}</strong>
                </p>
                <h3>{item.label}</h3>
                <p>{item.detail}</p>
                {item.href && <p><a href={item.href}>Gå videre</a></p>}
            </article>
        </li>
    ))}
</ul>
