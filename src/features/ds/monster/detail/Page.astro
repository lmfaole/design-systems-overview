---
import PageHeader from "@/components/ds/PageHeader/PageHeader.astro";
import type { PatternPost } from "@/data/monster/patterns";
import { serializePatternPost } from "../render";
import { MONSTER_PATTERN_SECTIONS } from "./sections";
import "./monster-detail.scss";
import "./components/PatternTableOfContents/styles.scss";
import "./components/PatternFeatureList/styles.scss";
import "./components/PatternDoAndDontsGrid/styles.scss";
import "./components/PatternImplementationCard/styles.scss";
import "./components/PatternExampleGrid/styles.scss";

interface Props {
    post: PatternPost;
}

const { post } = Astro.props;
const serializedPost = serializePatternPost(post);

const tableOfContentsItems = [
    MONSTER_PATTERN_SECTIONS.doAndDonts,
    ...(serializedPost.accessibilityConcerns.length > 0
        ? [MONSTER_PATTERN_SECTIONS.accessibility]
        : []),
    ...(serializedPost.implementation.length > 0
        ? [MONSTER_PATTERN_SECTIONS.implementation]
        : []),
    ...(serializedPost.furtherReading.length > 0
        ? [MONSTER_PATTERN_SECTIONS.furtherReading]
        : []),
];
---

<main class="page">
    <PageHeader title={serializedPost.title} description={serializedPost.description} />

    {tableOfContentsItems.length > 0 && (
        <nav class="monster-toc" aria-label="Innhold">
            <ol>
                {tableOfContentsItems.map((item) => (
                    <li class="monster-toc-item">
                        <a href={`#${item.id}`} class="monster-toc-link">
                            {item.label}
                        </a>
                    </li>
                ))}
            </ol>
        </nav>
    )}

    <section class="monster-section" aria-labelledby={MONSTER_PATTERN_SECTIONS.doAndDonts.id}>
        <h2 id={MONSTER_PATTERN_SECTIONS.doAndDonts.id}>
            {MONSTER_PATTERN_SECTIONS.doAndDonts.label}
        </h2>
        <div class="ds-grid monster-guidance-grid" data-columns={2}>
            <section
                class="monster-guidance-column"
                data-tone="success"
                aria-labelledby="monster-guidance-dos"
            >
                <h3 id="monster-guidance-dos" class="monster-guidance-heading">Gjør dette</h3>
                <ul class="ds-grid monster-feature-list" data-tone="success">
                    {serializedPost.doAndDonts.dos.map((item) => (
                        <li class="monster-feature-item">
                            <article class="monster-feature-body">
                                <p class="monster-feature-title">{item.title}</p>
                                {item.description && (
                                    <div class="monster-feature-description">{item.description}</div>
                                )}
                            </article>
                        </li>
                    ))}
                </ul>
            </section>
            <section
                class="monster-guidance-column"
                data-tone="error"
                aria-labelledby="monster-guidance-donts"
            >
                <h3 id="monster-guidance-donts" class="monster-guidance-heading">Unngå dette</h3>
                <ul class="ds-grid monster-feature-list" data-tone="error">
                    {serializedPost.doAndDonts.donts.map((item) => (
                        <li class="monster-feature-item">
                            <article class="monster-feature-body">
                                <p class="monster-feature-title">{item.title}</p>
                                {item.description && (
                                    <div class="monster-feature-description">{item.description}</div>
                                )}
                            </article>
                        </li>
                    ))}
                </ul>
            </section>
        </div>
    </section>

    {serializedPost.accessibilityConcerns.length > 0 && (
        <section class="monster-section" aria-labelledby={MONSTER_PATTERN_SECTIONS.accessibility.id}>
            <h2 id={MONSTER_PATTERN_SECTIONS.accessibility.id}>
                {MONSTER_PATTERN_SECTIONS.accessibility.label}
            </h2>
            <ul class="ds-grid monster-feature-list" data-tone="accent">
                {serializedPost.accessibilityConcerns.map((item) => (
                    <li class="monster-feature-item">
                        <article class="monster-feature-body">
                            <p class="monster-feature-title">{item.title}</p>
                            {item.description && (
                                <div class="monster-feature-description">{item.description}</div>
                            )}
                        </article>
                    </li>
                ))}
            </ul>
        </section>
    )}

    {serializedPost.implementation.length > 0 && (
        <section class="monster-section" aria-labelledby={MONSTER_PATTERN_SECTIONS.implementation.id}>
            <h2 id={MONSTER_PATTERN_SECTIONS.implementation.id}>
                {MONSTER_PATTERN_SECTIONS.implementation.label}
            </h2>
            <ul class="ds-grid monster-implementation-list">
                {serializedPost.implementation.map((implementation) => (
                    <li class="monster-implementation">
                        <article>
                            <header class="monster-implementation-copy">
                                <p class="monster-implementation-meta">
                                    <strong>Designsystem:</strong> {implementation.designSystem}
                                </p>
                                <h3>{implementation.title}</h3>
                                <div set:html={implementation.descriptionHtml} />
                            </header>
                            {implementation.components.length > 0 && (
                                <section class="monster-implementation-group">
                                    <h4>Komponenter</h4>
                                    <ul class="ds-grid monster-feature-list">
                                        {implementation.components.map((component) => (
                                            <li class="monster-feature-item">
                                                <article class="monster-feature-body">
                                                    <p class="monster-feature-title">
                                                        <a href={component.href}>{component.title}</a>
                                                    </p>
                                                </article>
                                            </li>
                                        ))}
                                    </ul>
                                </section>
                            )}
                            {implementation.liveExamplesHtml.length > 0 && (
                                <section class="monster-implementation-group" aria-label={`Live eksempler for ${implementation.title}`}>
                                    <h4>Live eksempler</h4>
                                    <ul class="bare-list monster-live-examples">
                                        {implementation.liveExamplesHtml.map((exampleHtml) => (
                                            <li class="monster-example-grid-item">
                                                <Fragment set:html={exampleHtml} />
                                            </li>
                                        ))}
                                    </ul>
                                </section>
                            )}
                        </article>
                    </li>
                ))}
            </ul>
        </section>
    )}

    {serializedPost.furtherReading.length > 0 && (
        <section class="monster-section" aria-labelledby={MONSTER_PATTERN_SECTIONS.furtherReading.id}>
            <h2 id={MONSTER_PATTERN_SECTIONS.furtherReading.id}>
                {MONSTER_PATTERN_SECTIONS.furtherReading.label}
            </h2>
            <ul class="ds-grid monster-feature-list">
                {serializedPost.furtherReading.map((item) => (
                    <li class="monster-feature-item">
                        <article class="monster-feature-body">
                            <p class="monster-feature-title">
                                <a href={item.href}>{item.title}</a>
                            </p>
                            {item.descriptionHtml && (
                                <div class="monster-feature-description">
                                    <Fragment set:html={item.descriptionHtml} />
                                </div>
                            )}
                        </article>
                    </li>
                ))}
            </ul>
        </section>
    )}
</main>
