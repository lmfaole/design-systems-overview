---
import "@/features/ds/jokul/_shared/components/TokenIllustration/token-illustration.scss";
import { tokenIllustrationVariants, type TokenIllustrationSlug } from "@/features/ds/jokul/_shared/components/TokenIllustration/shared";

interface Props {
    slug: TokenIllustrationSlug;
    surface?: "card" | "page";
}

const { slug, surface = "card" } = Astro.props;
const variant = tokenIllustrationVariants[slug];
const label = "label" in variant ? variant.label : undefined;
const specimenDataAttribute =
    surface === "page" ? { "data-token-specimen": slug } : { "data-token-card-specimen": slug };
const illustrationDataAttribute =
    surface === "page"
        ? { "data-token-illustration": slug }
        : { "data-token-card-illustration": slug };
---

<div
    class="token-illustration"
    data-surface={surface}
    data-token-illustration-bleed="true"
    {...illustrationDataAttribute}
>
    {variant.specimenTag === "strong" ? (
        <strong
            class="token-specimen"
            data-token-group={slug}
            data-token-overflow="large"
            {...specimenDataAttribute}
        >
            {label}
        </strong>
    ) : (
        <span
            class="token-specimen"
            data-token-group={slug}
            data-token-overflow="large"
            {...specimenDataAttribute}
        >
            {label}
        </span>
    )}
</div>
