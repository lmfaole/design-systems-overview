---
import PageHeader from "@/components/PageHeader.astro";
import { overviewInlineStyles } from "@/features/ds/jokul/overview/overview-inline-styles";
import TokenIllustration from "./TokenIllustration.astro";
import { tokenOverviewEntries } from "./token-overview-data";
---

<style is:inline set:html={overviewInlineStyles} />

<main class="page overview-page">
    <PageHeader
        title="Designtokens"
        description="Fundamentene i Jøkul — typografi, farger og spacing. Les disse for å forstå designsystemets kjerneprinsipper."
    />
    <div class="grid" data-columns={3}>
        {tokenOverviewEntries.map((entry) => (
            <a
                class="overview-card"
                data-kind="token"
                data-layout="illustrated"
                data-overview-card="token"
                href={entry.href}
            >
                <div class="overview-card-illustration" aria-hidden="true">
                    <TokenIllustration slug={entry.illustrationSlug} />
                </div>
                <div class="overview-card-copy">
                    <strong class="overview-card-title">{entry.title}</strong>
                </div>
            </a>
        ))}
    </div>
</main>
