---
import type { FormatterDoc } from "@/data/jokul/formatters";
import { getRelatedFormatterDocs } from "@/data/jokul/formatters";
import PageHeader from "@/components/PageHeader.astro";
import "./formatter-article.scss";
import {
    formatFormatterExampleResult,
    getFormatterImportStatement,
} from "./formatter-view";

interface Props {
    doc: FormatterDoc;
}

const { doc } = Astro.props;
const relatedDocs = getRelatedFormatterDocs(doc);
const importStatement = getFormatterImportStatement(doc.name, doc.package);
---

<article class="page formatter-article post-prose">
    <PageHeader title={doc.name} description={doc.description.long} />

    <section class="formatter-section">
        <h2 id="api">API</h2>
        <div class="formatter-meta-grid">
            <div class="formatter-card formatter-meta-card">
                <div class="formatter-card-stack" data-gap="xs">
                    <small>Kategori</small>
                    <strong>{doc.category}</strong>
                </div>
            </div>
            <div class="formatter-card formatter-meta-card">
                <div class="formatter-card-stack" data-gap="xs">
                    <small>Returnerer</small>
                    <code>{doc.returnType}</code>
                </div>
            </div>
            <div class="formatter-card formatter-meta-card">
                <div class="formatter-card-stack" data-gap="xs">
                    <small>Pakke</small>
                    <code>{doc.package}</code>
                </div>
            </div>
            <div class="formatter-card formatter-meta-card">
                <div class="formatter-card-stack" data-gap="xs">
                    <small>Signatur</small>
                    <code>{doc.signature}</code>
                </div>
            </div>
        </div>
        <div class="formatter-card-stack">
            <h3>Import</h3>
            <pre class="formatter-pre">
                <code>{importStatement}</code>
            </pre>
        </div>
    </section>

    <section class="formatter-section">
        <h2 id="eksempler">Eksempler</h2>
        <ul class="formatter-example-list">
            {doc.examples.map((example) => (
                <li>
                    <article class="formatter-card formatter-example-card">
                        <div class="formatter-card-stack">
                            <h3>{example.title}</h3>
                            {example.description && <p>{example.description}</p>}
                            <pre class="formatter-pre">
                                <code>{example.code.trim()}</code>
                            </pre>
                            {example.result && (
                                <div class="formatter-result">
                                    <small>{example.resultLabel ?? "Resultat"}</small>
                                    <code>{formatFormatterExampleResult(example.result)}</code>
                                </div>
                            )}
                        </div>
                    </article>
                </li>
            ))}
        </ul>
    </section>

    {doc.options && doc.options.length > 0 && (
        <section class="formatter-section">
            <h2 id="valg">Valg</h2>
            <dl class="formatter-definition-list">
                {doc.options.map((option) => (
                    <div>
                        <dt>
                            <code>{option.name}</code>
                        </dt>
                        <dd>
                            <span class="formatter-definition-meta">
                                Type: <code>{option.type}</code>
                                {option.defaultValue ? (
                                    <span>
                                        {" · "}
                                        Default: <code>{option.defaultValue}</code>
                                    </span>
                                ) : null}
                            </span>
                            <span>{option.description}</span>
                        </dd>
                    </div>
                ))}
            </dl>
        </section>
    )}

    {doc.helpers && doc.helpers.length > 0 && (
        <section class="formatter-section">
            <h2 id="hjelpere">Tilgjengelige hjelpere</h2>
            <dl class="formatter-definition-list">
                {doc.helpers.map((helper) => (
                    <div>
                        <dt>
                            <code>{helper.name}</code>
                        </dt>
                        <dd>{helper.description}</dd>
                    </div>
                ))}
            </dl>
        </section>
    )}

    {doc.relatedExports && doc.relatedExports.length > 0 && (
        <section class="formatter-section">
            <h2 id="relaterte-exports">Relaterte exports</h2>
            <dl class="formatter-definition-list">
                {doc.relatedExports.map((item) => (
                    <div>
                        <dt>
                            <code>{item.name}</code>
                        </dt>
                        <dd>{item.description}</dd>
                    </div>
                ))}
            </dl>
        </section>
    )}

    {doc.notes && doc.notes.length > 0 && (
        <section class="formatter-section">
            <h2 id="viktig-a-vite">Viktig å vite</h2>
            <ul>
                {doc.notes.map((note) => (
                    <li>{note}</li>
                ))}
            </ul>
        </section>
    )}

    {relatedDocs.length > 0 && (
        <section class="formatter-section">
            <h2 id="relaterte-funksjoner">Relaterte funksjoner</h2>
            <ul class="formatter-related-list">
                {relatedDocs.map((related) => (
                    <li>
                        <article class="formatter-card formatter-related-card">
                            <div class="formatter-card-stack" data-gap="xs">
                                <small>{related.category}</small>
                                <strong>
                                    <a href={`/ds/jokul/formatter/${related.id}`}>{related.name}</a>
                                </strong>
                                <span>{related.description.short}</span>
                            </div>
                        </article>
                    </li>
                ))}
            </ul>
        </section>
    )}
</article>
