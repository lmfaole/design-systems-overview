---
import { tokenPosts } from "@/features/ds/jokul/_token/data";
import { visibleFormatterCount } from "@/features/ds/jokul/formatters/formatter-overview-data";
import { visibleComponentCount } from "./component-overview-data";
import { overviewInlineStyles } from "./overview-inline-styles";

const visibleTokenCount = tokenPosts.length;
---

<style is:inline set:html={overviewInlineStyles} />

<main class="page overview-page overview-nav-page">
    <h1>Jøkul</h1>
    <div class="overview-nav-grid">
        <a
            class="overview-card"
            data-kind="component"
            data-layout="feature"
            data-overview-card="component"
            href="/ds/jokul/component"
        >
            <span class="overview-card-meta">{visibleComponentCount} komponenter</span>
            <strong class="overview-card-title">Komponenter</strong>
            <small class="overview-card-description">
                Utforsk alle komponentene samlet, med prop-tabeller, interaktive eksempler og
                dokumentasjon for bruk i praksis.
            </small>
        </a>
        <a
            class="overview-card"
            data-kind="token"
            data-layout="feature"
            data-overview-card="token"
            href="/ds/jokul/token"
        >
            <span class="overview-card-meta">{visibleTokenCount} tokenområder</span>
            <strong class="overview-card-title">Designtokens</strong>
            <small class="overview-card-description">
                Se alle fundamentene samlet, med illustrerte kort for typografi, farger,
                spacing, bevegelse og resten av tokensystemet.
            </small>
        </a>
        <a
            class="overview-card"
            data-kind="formatter"
            data-layout="feature"
            data-overview-card="formatter"
            href="/ds/jokul/formatter"
        >
            <span class="overview-card-meta">{visibleFormatterCount} formattere</span>
            <strong class="overview-card-title">Formattere</strong>
            <small class="overview-card-description">
                Dokumentasjon for utility-funksjoner i Jøkul som formaterer tall, datoer,
                norske identifikatorer og inputmasker i skjema.
            </small>
        </a>
    </div>
</main>
