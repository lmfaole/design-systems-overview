---
import type { PropShapeEntry } from "./prop-table";

interface Props {
    items: PropShapeEntry[];
    title: string;
}

const { items, title } = Astro.props;
---

{items.length > 0 && (
    <section class="component-type-group" aria-label={title}>
        <p class="component-type-group-title"><strong>{title}</strong></p>
        <div class="site-table-wrap">
            <table class="site-table component-type-table">
                <thead>
                    <tr>
                        <th scope="col">Navn</th>
                        <th scope="col">Type</th>
                        <th scope="col">Beskrivelse</th>
                    </tr>
                </thead>
                <tbody>
                    {items.map((item) => (
                        <tr>
                            <th scope="row">
                                <code>
                                    {item.name}
                                    {item.optional ? "?" : ""}
                                </code>
                            </th>
                            <td><code>{item.type}</code></td>
                            <td>{item.description ?? "—"}</td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </div>
    </section>
)}
