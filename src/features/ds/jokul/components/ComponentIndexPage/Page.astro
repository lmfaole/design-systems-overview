---
import { componentDocs } from "@/data/jokul/component-docs";
import { PageHeader } from "@/components/ds/PageHeader";
import "@/components/ds/Toolbar/toolbar.scss";
import "./styles.scss";

const visibleDocs = componentDocs
    .filter((doc) => doc.showOnOverview !== false)
    .sort((left, right) => left.name.localeCompare(right.name, "nb"));
const allDocs = [...componentDocs].sort((left, right) => left.name.localeCompare(right.name, "nb"));
const categories = Array.from(new Set(allDocs.map((doc) => doc.category))).sort((left, right) =>
    left.localeCompare(right, "nb"),
);
---

<main class="page component-index" data-component-index-page>
    <PageHeader
        title="Komponentdokumentasjon"
        description="Detaljert API-dokumentasjon, prop-tabeller og levende eksempler for komponenter fra Jøkul. Bruk dette som referanse når du bygger med designsystemet."
    />

    <p><a href="/ds/jokul/component/props">Props-oversikt</a></p>

    <section aria-label="Filtrer komponenter">

        <div class="ds-toolbar component-index-toolbar" data-component-index-form>
            <label class="site-field site-field-fill" for="component-query">
                <span>Søk etter komponent</span>
                <input
                    class="site-control"
                    id="component-query"
                    type="search"
                    name="q"
                    placeholder="Navn, beskrivelse eller pakke…"
                    data-component-index-query
                />
            </label>

            <label class="site-field" for="component-category">
                <span>Kategori</span>
                <select class="site-control" id="component-category" name="category" data-component-index-category>
                    <option value="">Alle kategorier</option>
                    {categories.map((category) => (
                        <option value={category}>{category}</option>
                    ))}
                </select>
            </label>

            <label class="site-field" for="component-status">
                <span>Status</span>
                <select class="site-control" id="component-status" name="status" data-component-index-status>
                    <option value="">Alle statuser</option>
                    <option value="stable">Stable</option>
                    <option value="beta">Beta</option>
                    <option value="deprecated">Deprecated</option>
                </select>
            </label>

            <label class="site-field" for="component-sort">
                <span>Sorter</span>
                <select class="site-control" id="component-sort" name="sort" data-component-index-sort>
                    <option value="az">A–Å</option>
                    <option value="za">Å–A</option>
                    <option value="most-props">Flest props</option>
                </select>
            </label>

            <label class="site-check" for="component-show-all">
                <input
                    id="component-show-all"
                    type="checkbox"
                    name="all"
                    value="1"
                    data-component-index-show-all
                />
                <span>Vis alle komponenter</span>
            </label>
        </div>

        <p class="count" data-component-index-count>{visibleDocs.length} komponenter</p>
    </section>

    <div class="ds-grid component-index-results" data-columns={4} data-component-index-results>
        {allDocs.map((doc) => (
            <a
                class="site-card site-card-link"
                href={`/ds/jokul/component/${doc.id}`}
                aria-label={doc.name}
                data-component-card=""
                data-component-id={doc.id}
                data-component-name={doc.name}
                data-component-search={`${doc.name} ${doc.description.short} ${doc.description.long} ${doc.package}`.toLowerCase()}
                data-component-category={doc.category}
                data-component-status={doc.status}
                data-component-props-count={String(doc.props.length)}
                data-component-show-on-overview={doc.showOnOverview === false ? "false" : "true"}
                hidden={doc.showOnOverview === false}
            >
                <strong>{doc.name}</strong>
                <small class="muted">{doc.description.short}</small>
            </a>
        ))}
    </div>

    <p class="muted" data-component-index-empty hidden>Ingen komponenter samsvarer med søket.</p>

    <noscript>
        <p>Filtrering og sortering av komponentlisten krever JavaScript i den statiske versjonen.</p>
    </noscript>

    <script>
        import { initComponentIndexPage } from "./page";

        initComponentIndexPage();
    </script>
</main>
