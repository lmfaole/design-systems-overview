---
import { ALL_PROP_ENTRIES } from "@/features/ds/jokul/_component-docs/prop-index";
import PageHeader from "@/components/PageHeader.astro";
import "@/components/toolbar.scss";
import "./styles.scss";

const entries = [...ALL_PROP_ENTRIES].sort((left, right) => left.propName.localeCompare(right.propName, "nb"));
---

<main class="page component-index" data-prop-index-page>
    <PageHeader
        title="Komponentdokumentasjon"
        description="Detaljert API-dokumentasjon, prop-tabeller og levende eksempler for komponenter fra Jøkul. Bruk dette som referanse når du bygger med designsystemet."
    />

    <p><a href="/ds/jokul/component">Komponenter</a></p>

    <section aria-label="Filtrer props">

        <div class="ds-toolbar component-index-toolbar" data-prop-index-form>
            <label for="prop-query">
                <span>Filtrer props</span>
                <input
                    id="prop-query"
                    type="search"
                    name="q"
                    placeholder="Propnavn eller komponentnavn…"
                    data-prop-index-query
                />
            </label>

            <label for="prop-sort">
                <span>Sorter</span>
                <select id="prop-sort" name="sort" data-prop-index-sort>
                    <option value="name-asc">A–Å</option>
                    <option value="name-desc">Å–A</option>
                    <option value="source-asc">Kilde</option>
                    <option value="used-by-desc">Mest brukt</option>
                </select>
            </label>
        </div>

        <p class="count" data-prop-index-count>{entries.length} props</p>
    </section>

    <div class="site-table-wrap">
        <table class="site-table">
            <caption>Props-oversikt</caption>
            <thead>
                <tr>
                    <th scope="col">Prop</th>
                    <th scope="col">Kilde</th>
                    <th scope="col">Brukt i</th>
                </tr>
            </thead>
            <tbody data-prop-index-body>
                {entries.map((entry) => (
                    <tr
                        data-prop-entry=""
                        data-prop-name={entry.propName}
                        data-prop-source={entry.source}
                        data-prop-used-by-count={String(entry.usedBy.length)}
                        data-prop-search={`${entry.propName} ${entry.usedBy.map((component) => component.name).join(" ")}`.toLowerCase()}
                    >
                        <td><code>{entry.propName}</code></td>
                        <td>{entry.source === "custom"
                            ? "Egendefinert"
                            : entry.source === "native"
                                ? "Native HTML"
                                : entry.source === "aria"
                                    ? "ARIA"
                                    : "React"}</td>
                        <td>
                            {entry.usedBy.map((component, index) => (
                                <span>
                                    <a href={`/ds/jokul/component/${component.id}`}>{component.name}</a>
                                    {index < entry.usedBy.length - 1 && ", "}
                                </span>
                            ))}
                        </td>
                    </tr>
                ))}
            </tbody>
        </table>
    </div>

    <p class="muted" data-prop-index-empty hidden>Ingen props samsvarer med søket.</p>

    <noscript>
        <p>Filtrering og sortering av props krever JavaScript i den statiske versjonen.</p>
    </noscript>

    <script>
        import { initPropIndexPage } from "./page";

        initPropIndexPage();
    </script>
</main>
