---
import type { SiteLink } from "../types";
import "./site-header.scss";

interface Props {
    brand: SiteLink;
    links: SiteLink[];
}

const { brand, links } = Astro.props;
---

<header class="site-header">
    <div class="page content">
        <a class="brand" href={brand.href}>{brand.label}</a>
        {links.length > 0 && (
            <nav aria-label="Primærnavigasjon" class="nav">
                <ul class="links">
                    {links.map((link) => (
                        <li>
                            <a class="link" href={link.href}>{link.label}</a>
                        </li>
                    ))}
                </ul>
            </nav>
        )}
    </div>
</header>
