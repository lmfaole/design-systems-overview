---
import TableOfContents from "@/components/TableOfContents.astro";
import {
    getComponentCountLabel,
    getCoverageLabels,
    getDocumentationStatusLabel,
    getDocumentedDesignSystems,
    getDesignSystems,
    getExternalDesignSystems,
    getInstallGuideLabel,
    getLocalBasePath,
    getPrimarySystemHref,
    getPackageLabel,
    getPlannedLocalDesignSystems,
    getRoadmapItems,
} from "@/data/ds-overview";
import DesignSystemExternalLinks from "@/components/DesignSystemExternalLinks.astro";

const systems = getDesignSystems();
const documentedSystems = getDocumentedDesignSystems();
const plannedSystems = getPlannedLocalDesignSystems();
const externalSystems = getExternalDesignSystems();
---

<main class="page">
    <header class="ds-page-header">
        <h1 class="title">Designsystemer</h1>
        <p class="description">
            Katalog over designsystemer vi følger, med plan for installasjon, dokumentasjon og hvordan vi skiller komponenter fra øvrige assets.
        </p>
    </header>

    <form role="search" action="/ds/søk" method="get">
        <label for="design-system-search">Søk</label>
        <input
            id="design-system-search"
            type="search"
            name="q"
            placeholder="Mønster eller side i den lokale dokumentasjonen…"
        />
        <button type="submit">Søk</button>
    </form>
    <p>Søket dekker den lokale mønsterdokumentasjonen og sidene under <code>/ds</code>.</p>

    <TableOfContents />

    <section>
        <div>
            <h2>Dokumenterte designsystemer</h2>
            <p>Disse har egne sider og lokal dokumentasjon i repoet.</p>
        </div>
        {documentedSystems.length === 0 ? (
            <p>Ingen designsystemer har lokal dokumentasjon i repoet ennå.</p>
        ) : (
            <ul>
                {documentedSystems.map((system) => {
                    const componentCountLabel = getComponentCountLabel(system);
                    const installGuideLabel = getInstallGuideLabel(system);
                    const coverageLabels = getCoverageLabels(system);
                    const packageLabel = getPackageLabel(system);
                    const primaryHref = getPrimarySystemHref(system);

                    return (
                        <li>
                            <article>
                                <h3>
                                    <a href={primaryHref}>{system.name}</a>
                                </h3>
                                <p>{system.description}</p>
                                <p>{getDocumentationStatusLabel(system)}</p>
                                {packageLabel && <p>Primærpakke: <code>{packageLabel}</code></p>}
                                {installGuideLabel && <p>{installGuideLabel}</p>}
                                {componentCountLabel && <p>{componentCountLabel}</p>}
                                {coverageLabels.length > 0 && (
                                    <>
                                        <p>Dekning:</p>
                                        <ul>
                                            {coverageLabels.map((label) => (
                                                <li>{label}</li>
                                            ))}
                                        </ul>
                                    </>
                                )}
                                <DesignSystemExternalLinks links={system.externalLinks} />
                            </article>
                        </li>
                    );
                })}
            </ul>
        )}
    </section>

    <section>
        <div>
            <h2>Planlagte designsystemer</h2>
            <p>Disse har en lokal dokumentasjonsplan i repoet, men selve rutene og innholdet er ikke bygget ut ennå.</p>
        </div>
        {plannedSystems.length === 0 ? (
            <p>Ingen designsystemer har en planlagt lokal dokumentasjonsstruktur i repoet ennå.</p>
        ) : (
            <ul>
                {plannedSystems.map((system) => {
                    const componentCountLabel = getComponentCountLabel(system);
                    const installGuideLabel = getInstallGuideLabel(system);
                    const coverageLabels = getCoverageLabels(system);
                    const localBasePath = getLocalBasePath(system);
                    const roadmapItems = getRoadmapItems(system);
                    const packageLabel = getPackageLabel(system);

                    return (
                        <li>
                            <article>
                                <h3>
                                    <a href={system.docs}>{system.name}</a>
                                </h3>
                                <p>{system.description}</p>
                                <p>{getDocumentationStatusLabel(system)}</p>
                                {localBasePath && <p>Planlagt lokal base: <code>{localBasePath}</code></p>}
                                {packageLabel && <p>Primærpakke: <code>{packageLabel}</code></p>}
                                {installGuideLabel && <p>{installGuideLabel}</p>}
                                {componentCountLabel && <p>{componentCountLabel}</p>}
                                {coverageLabels.length > 0 && (
                                    <>
                                        <p>Planlagt omfang:</p>
                                        <ul>
                                            {coverageLabels.map((label) => (
                                                <li>{label}</li>
                                            ))}
                                        </ul>
                                    </>
                                )}
                                {roadmapItems.length > 0 && (
                                    <>
                                        <p>Neste steg:</p>
                                        <ul>
                                            {roadmapItems.map((item) => (
                                                <li>{item}</li>
                                            ))}
                                        </ul>
                                    </>
                                )}
                                <DesignSystemExternalLinks links={system.externalLinks} />
                            </article>
                        </li>
                    );
                })}
            </ul>
        )}
    </section>

    <section>
        <div>
            <h2>Kun eksterne designsystemer</h2>
            <p>Disse er registrert i katalogen, men har foreløpig ikke en lokal plan eller egne ruter i repoet.</p>
        </div>
        {externalSystems.length === 0 ? (
            <p>Alle registrerte designsystemer har enten lokal dokumentasjon eller en plan for det.</p>
        ) : (
            <ul>
                {externalSystems.map((system) => {
                    const componentCountLabel = getComponentCountLabel(system);
                    const installGuideLabel = getInstallGuideLabel(system);
                    const coverageLabels = getCoverageLabels(system);
                    const packageLabel = getPackageLabel(system);

                    return (
                        <li>
                            <article>
                                <h3>
                                    <a href={system.docs}>{system.name}</a>
                                </h3>
                                <p>{system.description}</p>
                                <p>{getDocumentationStatusLabel(system)}</p>
                                {packageLabel && <p>Primærpakke: <code>{packageLabel}</code></p>}
                                {installGuideLabel && <p>{installGuideLabel}</p>}
                                {componentCountLabel && <p>{componentCountLabel}</p>}
                                {coverageLabels.length > 0 && (
                                    <>
                                        <p>Asset-områder:</p>
                                        <ul>
                                            {coverageLabels.map((label) => (
                                                <li>{label}</li>
                                            ))}
                                        </ul>
                                    </>
                                )}
                                <DesignSystemExternalLinks links={system.externalLinks} />
                            </article>
                        </li>
                    );
                })}
            </ul>
        )}
    </section>

    <section>
        <div>
            <h2>Alle registrerte designsystemer</h2>
            <p>Samlet oversikt over hvilke systemer som er katalogisert for videre lokal dokumentasjon.</p>
        </div>
        <ul>
            {systems.map((system) => (
                <li>
                    <article>
                        <h3>
                            <a href={system.docs}>{system.name}</a>
                        </h3>
                        <p>{system.description}</p>
                        <p>{getDocumentationStatusLabel(system)}</p>
                    </article>
                </li>
            ))}
        </ul>
    </section>
</main>
