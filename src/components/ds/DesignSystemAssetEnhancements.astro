<script>
    import type {
        DesignSystemExampleCode,
        DesignSystemInteractiveExampleClientConfig,
        DesignSystemInteractiveExampleControl,
    } from "@/data/design-systems";
    import { renderInteractiveExampleState } from "@/data/design-systems/interactive-runtime";

    const interactiveExampleConfigs = new WeakMap<
        HTMLElement,
        DesignSystemInteractiveExampleClientConfig
    >();
    const interactiveExampleEventEntries = new WeakMap<HTMLElement, string[]>();
    const interactiveExampleEventCleanup = new WeakMap<HTMLElement, () => void>();

    const getInteractiveConfig = (
        root: HTMLElement,
    ): DesignSystemInteractiveExampleClientConfig | null => {
        const cached = interactiveExampleConfigs.get(root);

        if (cached) {
            return cached;
        }

        const configElement = root.querySelector('[data-ds-interactive-config]');

        if (!(configElement instanceof HTMLScriptElement)) {
            return null;
        }

        try {
            const config = JSON.parse(
                configElement.textContent || "null",
            ) as DesignSystemInteractiveExampleClientConfig | null;

            if (
                !config ||
                !Array.isArray(config.controls) ||
                typeof config.rendererId !== "string"
            ) {
                return null;
            }

            interactiveExampleConfigs.set(root, config);
            return config;
        } catch {
            return null;
        }
    };

    const getControlValue = (
        control: DesignSystemInteractiveExampleControl,
        root: HTMLElement,
    ): string | boolean => {
        const field = root.querySelector(`[data-ds-interactive-control="${control.name}"]`);

        if (control.kind === "boolean") {
            return field instanceof HTMLInputElement ? field.checked : false;
        }

        return field instanceof HTMLSelectElement ? field.value : "";
    };

    const getEventLogEntries = (root: HTMLElement): string[] =>
        interactiveExampleEventEntries.get(root) ?? [];

    const getEventTargetLabel = (target: EventTarget | null): string => {
        if (!(target instanceof Element)) {
            return "ukjent mål";
        }

        const tagName = target.tagName.toLowerCase();
        const ariaLabel = target.getAttribute("aria-label")?.trim();
        const textContent = target.textContent?.replace(/\s+/g, " ").trim();
        const label = ariaLabel || textContent;

        if (!label) {
            return `<${tagName}>`;
        }

        return `${tagName} "${label.slice(0, 80)}"`;
    };

    const renderEventLog = (root: HTMLElement): void => {
        const eventsRoot = root.querySelector("[data-ds-interactive-events]");

        if (!(eventsRoot instanceof HTMLElement)) {
            return;
        }

        const eventsList = eventsRoot.querySelector("[data-ds-interactive-events-list]");
        const emptyState = eventsRoot.querySelector("[data-ds-interactive-events-empty]");

        if (!(eventsList instanceof HTMLOListElement) || !(emptyState instanceof HTMLElement)) {
            return;
        }

        eventsList.replaceChildren();

        const entries = getEventLogEntries(root);

        emptyState.hidden = entries.length > 0;
        eventsList.hidden = entries.length === 0;

        for (const entry of entries) {
            const item = document.createElement("li");
            item.textContent = entry;
            eventsList.append(item);
        }
    };

    const recordEventLogEntry = (root: HTMLElement, event: Event): void => {
        const config = getInteractiveConfig(root);
        const eventLog = config?.eventLog;

        if (!eventLog) {
            return;
        }

        const maxEntries = Math.max(1, eventLog.maxEntries ?? 8);
        const currentTargetLabel = getEventTargetLabel(event.currentTarget);
        const entries = [
            `${event.type} på ${currentTargetLabel}`,
            ...getEventLogEntries(root),
        ].slice(0, maxEntries);

        interactiveExampleEventEntries.set(root, entries);
        renderEventLog(root);
    };

    const bindEventLogListeners = (
        root: HTMLElement,
        previewRoot: HTMLElement,
    ): void => {
        const previousCleanup = interactiveExampleEventCleanup.get(root);

        if (typeof previousCleanup === "function") {
            previousCleanup();
        }

        const config = getInteractiveConfig(root);
        const eventLog = config?.eventLog;

        if (!eventLog || !(previewRoot instanceof HTMLElement)) {
            interactiveExampleEventCleanup.delete(root);
            renderEventLog(root);
            return;
        }

        const matchedTargets = eventLog.targetSelector
            ? Array.from(previewRoot.querySelectorAll(eventLog.targetSelector))
            : [previewRoot];
        const targets = matchedTargets.length > 0 ? matchedTargets : [previewRoot];
        const listeners: Array<() => void> = [];

        for (const target of targets) {
            if (!(target instanceof Element)) {
                continue;
            }

            for (const eventName of eventLog.events) {
                const listener = (event: Event) => recordEventLogEntry(root, event);
                target.addEventListener(eventName, listener);
                listeners.push(() => target.removeEventListener(eventName, listener));
            }
        }

        interactiveExampleEventCleanup.set(root, () => {
            for (const dispose of listeners) {
                dispose();
            }
        });

        renderEventLog(root);
    };

    const renderCodeExamples = (
        root: HTMLElement,
        codeExamples: DesignSystemExampleCode[],
    ): void => {
        const codeRoot = root.querySelector("[data-ds-interactive-code]");

        if (!(codeRoot instanceof HTMLElement)) {
            return;
        }

        codeRoot.replaceChildren();

        if (!Array.isArray(codeExamples) || codeExamples.length === 0) {
            codeRoot.hidden = true;
            return;
        }

        codeRoot.hidden = false;

        const heading = document.createElement("h4");
        heading.textContent = "Kode";
        codeRoot.append(heading);

        for (const codeExample of codeExamples) {
            const figure = document.createElement("figure");
            const caption = document.createElement("figcaption");
            const label = document.createElement("strong");
            label.textContent = codeExample.label;
            caption.append(label);

            if (codeExample.language) {
                caption.append(` · ${codeExample.language}`);
            }

            const pre = document.createElement("pre");
            const code = document.createElement("code");
            code.textContent = codeExample.code;
            pre.append(code);
            figure.append(caption, pre);
            codeRoot.append(figure);
        }
    };

    const renderNotes = (root: HTMLElement, notes: string[] | undefined): void => {
        const notesRoot = root.querySelector("[data-ds-interactive-notes]");

        if (!(notesRoot instanceof HTMLElement)) {
            return;
        }

        notesRoot.replaceChildren();

        if (!Array.isArray(notes) || notes.length === 0) {
            notesRoot.hidden = true;
            return;
        }

        notesRoot.hidden = false;

        const heading = document.createElement("h4");
        heading.textContent = "Notater";
        notesRoot.append(heading);

        const list = document.createElement("ul");

        for (const note of notes) {
            const item = document.createElement("li");
            item.textContent = note;
            list.append(item);
        }

        notesRoot.append(list);
    };

    const updateInteractiveExample = (root: HTMLElement | null): void => {
        if (!(root instanceof HTMLElement)) {
            return;
        }

        const config = getInteractiveConfig(root);

        if (!config) {
            return;
        }

        const values = Object.fromEntries(
            config.controls.map((control: DesignSystemInteractiveExampleControl) => [
                control.name,
                getControlValue(control, root),
            ]),
        );
        const state = renderInteractiveExampleState(config.rendererId, values);

        if (!state) {
            return;
        }

        const previewRoot = root.querySelector("[data-ds-interactive-preview]");

        if (previewRoot instanceof HTMLElement) {
            previewRoot.innerHTML = state.previewHtml;
            bindEventLogListeners(root, previewRoot);
        }

        renderCodeExamples(root, state.codeExamples);
        renderNotes(root, state.notes);
        renderEventLog(root);
    };

    const getInteractiveRoot = (target: EventTarget | null): HTMLElement | null =>
        target instanceof Element
            ? target.closest("[data-ds-interactive-example]")
            : null;

    document.addEventListener("input", (event) => {
        updateInteractiveExample(getInteractiveRoot(event.target));
    });

    document.addEventListener("change", (event) => {
        updateInteractiveExample(getInteractiveRoot(event.target));
    });

    document.querySelectorAll("[data-ds-interactive-example]").forEach((root) => {
        if (root instanceof HTMLElement) {
            updateInteractiveExample(root);
        }
    });
</script>
