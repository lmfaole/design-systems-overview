---
import PageHeader from "@/components/PageHeader.astro";
import { getPatternHref, patternPosts } from "@/data/mønster/patterns";
import { PATTERN_CATEGORY_LABELS } from "@/data/mønster/types";

const categories = Array.from(new Set(patternPosts.map((post) => post.category))).sort((a, b) =>
    PATTERN_CATEGORY_LABELS[a].localeCompare(PATTERN_CATEGORY_LABELS[b], "nb"),
);
---

<section class="mønster-hero">
    <PageHeader
        title="Mønster"
        description="Anbefalte løsninger på gjentakende UI-problemer. Hver side skal dekke én konkret situasjon, ikke en bred samlepost."
    />
</section>

<p>
    Del opp brede temaer i smale mønstre. Skriv egne sider for konkrete situasjoner som lokal
    lastestatus, skjelettvisning og fremdrift ved venting, i stedet for å samle alt under én
    generell overskrift.
</p>

{categories.map((category) => {
    const posts = patternPosts.filter((post) => post.category === category);

    return (
        <section class="mønster-section" aria-labelledby={`kategori-${category}`}>
            <h2 id={`kategori-${category}`}>{PATTERN_CATEGORY_LABELS[category]}</h2>
            <ul class="grid bare-list mønster-patterns" data-columns={2}>
                {posts.map((post) => (
                    <li class="mønster-pattern">
                        <a href={getPatternHref(post)} class="mønster-pattern-link">
                            <h3>{post.title}</h3>
                            <p>{post.description}</p>
                        </a>
                    </li>
                ))}
            </ul>
        </section>
    );
})}
