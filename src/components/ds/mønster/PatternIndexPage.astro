---
import PageHeader from "@/components/PageHeader.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { patternRestartPlan } from "@/data/mønster/plan";
---

<section>
    <PageHeader
        title={patternRestartPlan.title}
        description={patternRestartPlan.description}
    />
</section>

{patternRestartPlan.intro.map((paragraph) => <p>{paragraph}</p>)}

<TableOfContents />

{patternRestartPlan.sections.map((section) => (
    <section aria-labelledby={section.id}>
        <h2 id={section.id}>{section.title}</h2>
        {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        {section.subsections?.map((subsection) => (
            <section aria-labelledby={subsection.id}>
                <h3 id={subsection.id}>{subsection.title}</h3>
                {subsection.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
                {subsection.items && (
                    <ul>
                        {subsection.items.map((item) => <li>{item}</li>)}
                    </ul>
                )}
                {subsection.orderedItems && (
                    <ol>
                        {subsection.orderedItems.map((item) => <li>{item}</li>)}
                    </ol>
                )}
                {subsection.links && (
                    <ul>
                        {subsection.links.map((link) => (
                            <li>
                                <a href={link.href}>{link.title}</a>
                                : {link.description}
                            </li>
                        ))}
                    </ul>
                )}
            </section>
        ))}
    </section>
))}
