---
import "@fremtind/jokul/styles/fonts/webfonts.scss";
import { SiteHeader } from "@/components/site/SiteHeader";
import { SiteFooter } from "@/components/site/SiteFooter";
import { SiteBreadcrumb } from "@/components/site/SiteBreadcrumb";
import {
    siteBrand,
    siteFooterNote,
    siteFooterSections,
    siteHeaderLinks,
} from "@/data/site/navigation";
import { DEFAULT_DESCRIPTION, SITE_NAME, SITE_URL } from "@/site/seo";
import { jokulOverviewThemeStyles } from "./jokulOverviewThemeStyles";

interface Props {
    title?: string;
    description?: string;
    path?: string;
    type?: "website" | "article";
    noIndex?: boolean;
}

const {
    title = SITE_NAME,
    description = DEFAULT_DESCRIPTION,
    path = "/",
    type = "website",
    noIndex = false,
} = Astro.props;

const canonicalUrl = new URL(path, SITE_URL).toString();
const pageTitle = title === SITE_NAME ? SITE_NAME : `${title} | ${SITE_NAME}`;
---

<html lang="no">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{pageTitle}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:site_name" content={SITE_NAME} />
        <meta property="og:locale" content="nb_NO" />
        <meta property="og:type" content={type} />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <link rel="icon" href="/favicon.ico" />
        {noIndex && <meta name="robots" content="noindex,follow" />}
        <style is:inline set:html={jokulOverviewThemeStyles} />
    </head>
    <body>
        <SiteHeader brand={siteBrand} links={siteHeaderLinks} />
        <SiteBreadcrumb pathname={path} />
        <div class="jkl-site site-layout" data-theme="auto">
            <slot />
        </div>
        <SiteFooter
            sections={siteFooterSections}
            note={siteFooterNote}
        />
    </body>
</html>
